# Copy this file to `.env.local` and fill in the values from your
# Supabase project dashboard (Project Settings -> API).
#
# .env.local is gitignored. Never commit real values.
#
# IMPORTANT: only the `anon` (public) key belongs here. The
# `service_role` key bypasses Row Level Security and must never be
# exposed to the browser or committed anywhere.

# Supabase project URL, e.g. https://abcdxyz.supabase.co
VITE_SUPABASE_URL=

# Supabase anon (publishable) key. Safe to ship to browsers because it is
# constrained by Row Level Security policies on the database.
# New-format keys look like `sb_publishable_...`; older projects use a
# JWT (`eyJ...`). Either works. Never use the `sb_secret_...` key here.
VITE_SUPABASE_ANON_KEY=

# n8n webhook URL used to trigger data-population workflows from the app.
# This URL itself is not a secret, but treat it like one if the workflow
# performs privileged actions without auth.
VITE_N8N_WEBHOOK_URL=
